{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "dotnet format 2>/dev/null || true",
            "statusMessage": "Formatting before commit..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "dotnet format 2>/dev/null || true",
            "statusMessage": "Formatting code..."
          }
        ]
      }
    ]
  }
}
