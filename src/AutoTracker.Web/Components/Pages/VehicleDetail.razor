@page "/vehicles/{Id:int}"
@rendermode InteractiveServer
@inject IVehicleRepository VehicleRepo
@inject IFuelLogRepository FuelRepo
@inject IMaintenanceRepository MaintenanceRepo
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@(_vehicle?.Name ?? "Vehicle") — AutoTracker</PageTitle>

@if (_vehicle is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-2 pa-0" />

    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="2">
        <div>
            <MudText Typo="Typo.h4">@_vehicle.Name</MudText>
            <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
                @_vehicle.Year @_vehicle.Make @_vehicle.Model
            </MudText>
        </div>
        <MudSpacer />
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Edit"
                   OnClick="OpenEditDialog">Edit</MudButton>
    </MudStack>

    <MudGrid Class="mb-6" Spacing="2">
        <MudItem xs="6" sm="3">
            <MudField Label="Fuel Type" Variant="Variant.Outlined">@_vehicle.FuelType</MudField>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudField Label="Tank Capacity" Variant="Variant.Outlined">
                @(_vehicle.TankCapacity.HasValue ? $"{_vehicle.TankCapacity} gal" : "—")
            </MudField>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudField Label="VIN" Variant="Variant.Outlined">@(_vehicle.VIN ?? "—")</MudField>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudField Label="License Plate" Variant="Variant.Outlined">@(_vehicle.LicensePlate ?? "—")</MudField>
        </MudItem>
    </MudGrid>

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true">
        <MudTabPanel Text="Fuel Logs" Icon="@Icons.Material.Filled.LocalGasStation">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenAddFuelDialog" Class="mb-3">Add Fuel Log</MudButton>

            @if (_fuelLogs is null)
            {
                <MudProgressCircular Indeterminate="true" />
            }
            else if (_fuelLogs.Count == 0)
            {
                <MudAlert Severity="Severity.Info">No fuel logs for this vehicle yet.</MudAlert>
            }
            else
            {
                <MudDataGrid T="FuelLog" Items="_fuelLogs" Dense="true" Hover="true" Striped="true" Elevation="0">
                    <Columns>
                        <PropertyColumn Property="x => x.Date" Title="Date" Format="yyyy-MM-dd" />
                        <PropertyColumn Property="x => x.Odometer" Title="Odometer" Format="N0" />
                        <PropertyColumn Property="x => x.Gallons" Title="Gallons" Format="F3" />
                        <TemplateColumn Title="Total Cost" SortBy="x => x.TotalCost">
                            <CellTemplate>$@context.Item.TotalCost.ToString("F2")</CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="MPG" SortBy="x => x.Mpg">
                            <CellTemplate>
                                @if (context.Item.Mpg.HasValue)
                                { @context.Item.Mpg.Value.ToString("F1") }
                                else
                                { <MudText Color="Color.Secondary" Typo="Typo.body2">N/A</MudText> }
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="¢/Mile" SortBy="x => x.CostPerMile">
                            <CellTemplate>
                                @if (context.Item.CostPerMile.HasValue)
                                { @((context.Item.CostPerMile.Value * 100).ToString("F1")) }
                                else
                                { <MudText Color="Color.Secondary" Typo="Typo.body2">N/A</MudText> }
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Mi Since Fill" SortBy="x => x.MilesSinceLastFillup">
                            <CellTemplate>
                                @if (context.Item.MilesSinceLastFillup.HasValue)
                                { @context.Item.MilesSinceLastFillup.Value.ToString("N0") }
                                else
                                { <MudText Color="Color.Secondary" Typo="Typo.body2">N/A</MudText> }
                            </CellTemplate>
                        </TemplateColumn>
                        <PropertyColumn Property="x => x.FuelStation" Title="Station" />
                        <TemplateColumn Title="" CellClass="d-flex justify-end gap-1" Sortable="false" Filterable="false">
                            <CellTemplate>
                                <MudTooltip Text="Edit">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                   OnClick="@(() => OpenEditFuelDialog(context.Item))" />
                                </MudTooltip>
                                <MudTooltip Text="Delete">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                   Color="Color.Error" OnClick="@(() => DeleteFuelLog(context.Item))" />
                                </MudTooltip>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                </MudDataGrid>
            }
        </MudTabPanel>
        <MudTabPanel Text="Maintenance" Icon="@Icons.Material.Filled.Build">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenAddMaintenanceDialog" Class="mb-3">Add Maintenance</MudButton>

            @if (_maintenanceLogs is null)
            {
                <MudProgressCircular Indeterminate="true" />
            }
            else if (_maintenanceLogs.Count == 0)
            {
                <MudAlert Severity="Severity.Info">No maintenance logs for this vehicle yet.</MudAlert>
            }
            else
            {
                <MudDataGrid T="MaintenanceLog" Items="_maintenanceLogs" Dense="true" Hover="true" Striped="true" Elevation="0">
                    <Columns>
                        <PropertyColumn Property="x => x.Date" Title="Date" Format="yyyy-MM-dd" />
                        <PropertyColumn Property="x => x.Odometer" Title="Odometer" Format="N0" />
                        <PropertyColumn Property="x => x.ServiceType" Title="Service Type" />
                        <TemplateColumn Title="Cost" SortBy="x => x.Cost">
                            <CellTemplate>$@context.Item.Cost.ToString("F2")</CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Vendor" SortBy="x => x.Vendor">
                            <CellTemplate>
                                @if (context.Item.Vendor is not null)
                                { @context.Item.Vendor }
                                else
                                { <MudText Color="Color.Secondary" Typo="Typo.body2">—</MudText> }
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Description" SortBy="x => x.Description">
                            <CellTemplate>
                                @if (context.Item.Description is not null)
                                { @context.Item.Description }
                                else
                                { <MudText Color="Color.Secondary" Typo="Typo.body2">—</MudText> }
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="" CellClass="d-flex justify-end gap-1" Sortable="false" Filterable="false">
                            <CellTemplate>
                                <MudTooltip Text="Edit">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                   OnClick="@(() => OpenEditMaintenanceDialog(context.Item))" />
                                </MudTooltip>
                                <MudTooltip Text="Delete">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                   Color="Color.Error" OnClick="@(() => DeleteMaintenanceLog(context.Item))" />
                                </MudTooltip>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                </MudDataGrid>
            }
        </MudTabPanel>
        <MudTabPanel Text="Expenses" Icon="@Icons.Material.Filled.Receipt">
            <MudText Color="Color.Secondary">Expense data available in the Expenses iteration.</MudText>
        </MudTabPanel>
    </MudTabs>
}

@code {
    [Parameter] public int Id { get; set; }

    private Vehicle? _vehicle;
    private List<FuelLog>? _fuelLogs;
    private List<MaintenanceLog>? _maintenanceLogs;

    private List<BreadcrumbItem> _breadcrumbs =
    [
        new("Vehicles", href: "vehicles"),
        new("Detail", href: null, disabled: true)
    ];

    protected override async Task OnInitializedAsync()
    {
        _vehicle = await VehicleRepo.GetByIdAsync(Id);
        if (_vehicle is not null)
            _breadcrumbs[1] = new BreadcrumbItem(_vehicle.Name, href: null, disabled: true);
        await Task.WhenAll(LoadFuelLogsAsync(), LoadMaintenanceLogsAsync());
    }

    private async Task LoadFuelLogsAsync()
    {
        var logs = await FuelRepo.GetByVehicleIdAsync(Id);
        _fuelLogs = AutoTracker.Core.Calculations.FuelLogCalculator.Calculate(logs)
            .OrderByDescending(l => l.Date).ThenByDescending(l => l.Odometer).ToList();
    }

    private async Task LoadMaintenanceLogsAsync()
    {
        var logs = await MaintenanceRepo.GetByVehicleIdAsync(Id);
        _maintenanceLogs = logs.OrderByDescending(l => l.Date).ThenByDescending(l => l.Odometer).ToList();
    }

    private async Task OpenEditDialog()
    {
        var parameters = new DialogParameters<VehicleDialog> { { x => x.Vehicle, _vehicle } };
        var dialog = await DialogService.ShowAsync<VehicleDialog>("Edit Vehicle", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            _vehicle = await VehicleRepo.GetByIdAsync(Id);
            Snackbar.Add("Vehicle updated.", Severity.Success);
        }
    }

    private async Task OpenAddFuelDialog()
    {
        var parameters = new DialogParameters<FuelLogDialog> { { x => x.PreselectedVehicleId, Id } };
        var dialog = await DialogService.ShowAsync<FuelLogDialog>("Add Fuel Log", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await LoadFuelLogsAsync();
            Snackbar.Add("Fuel log added.", Severity.Success);
        }
    }

    private async Task OpenEditFuelDialog(FuelLog log)
    {
        var parameters = new DialogParameters<FuelLogDialog> { { x => x.FuelLog, log } };
        var dialog = await DialogService.ShowAsync<FuelLogDialog>("Edit Fuel Log", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await LoadFuelLogsAsync();
            Snackbar.Add("Fuel log updated.", Severity.Success);
        }
    }

    private async Task DeleteFuelLog(FuelLog log)
    {
        var confirmParams = new DialogParameters<ConfirmDialog>
        {
            { x => x.Message, $"Delete fuel log for {log.Date:yyyy-MM-dd}? This cannot be undone." },
            { x => x.ConfirmText, "Delete" }
        };
        var confirmDialog = await DialogService.ShowAsync<ConfirmDialog>("Delete Fuel Log", confirmParams);
        var confirmed = await confirmDialog.Result;
        if (confirmed is { Canceled: false })
        {
            await FuelRepo.DeleteAsync(log.Id);
            await LoadFuelLogsAsync();
            Snackbar.Add("Fuel log deleted.", Severity.Success);
        }
    }

    private async Task OpenAddMaintenanceDialog()
    {
        var parameters = new DialogParameters<MaintenanceLogDialog> { { x => x.PreselectedVehicleId, Id } };
        var dialog = await DialogService.ShowAsync<MaintenanceLogDialog>("Add Maintenance Log", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await LoadMaintenanceLogsAsync();
            Snackbar.Add("Maintenance log added.", Severity.Success);
        }
    }

    private async Task OpenEditMaintenanceDialog(MaintenanceLog log)
    {
        var parameters = new DialogParameters<MaintenanceLogDialog> { { x => x.MaintenanceLog, log } };
        var dialog = await DialogService.ShowAsync<MaintenanceLogDialog>("Edit Maintenance Log", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await LoadMaintenanceLogsAsync();
            Snackbar.Add("Maintenance log updated.", Severity.Success);
        }
    }

    private async Task DeleteMaintenanceLog(MaintenanceLog log)
    {
        var confirmParams = new DialogParameters<ConfirmDialog>
        {
            { x => x.Message, $"Delete {log.ServiceType} on {log.Date:yyyy-MM-dd}? This cannot be undone." },
            { x => x.ConfirmText, "Delete" }
        };
        var confirmDialog = await DialogService.ShowAsync<ConfirmDialog>("Delete Maintenance Log", confirmParams);
        var confirmed = await confirmDialog.Result;
        if (confirmed is { Canceled: false })
        {
            await MaintenanceRepo.DeleteAsync(log.Id);
            await LoadMaintenanceLogsAsync();
            Snackbar.Add("Maintenance log deleted.", Severity.Success);
        }
    }
}
