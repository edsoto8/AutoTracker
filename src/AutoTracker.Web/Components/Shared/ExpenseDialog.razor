@inject IVehicleRepository VehicleRepo
@inject IExpenseRepository ExpenseRepo

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <MudSelect T="int" Value="_model.VehicleId" Label="Vehicle" Required="true"
                               RequiredError="Vehicle is required." Disabled="@(PreselectedVehicleId > 0)"
                               AnchorOrigin="Origin.BottomLeft"
                               ValueChanged="@((int id) => { _model.VehicleId = id; })">
                        @foreach (var v in _vehicles)
                        {
                            <MudSelectItem Value="v.Id">@v.Name (@v.Year @v.Make @v.Model)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="_date" Label="Date" Required="true"
                                   MaxDate="DateTime.Today" DateFormat="yyyy-MM-dd" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect @bind-Value="_model.Category" Label="Category" Required="true"
                               AnchorOrigin="Origin.BottomLeft">
                        @foreach (var cat in Enum.GetValues<ExpenseCategory>())
                        {
                            <MudSelectItem Value="cat">@cat</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.Description" Label="Description" Required="true"
                                  RequiredError="Description is required." MaxLength="200" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="_model.Amount" Label="Amount ($)" Required="true"
                                     Min="0.01m" Format="F2" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.Notes" Label="Notes (optional)" MaxLength="200" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Expense? Expense { get; set; }
    [Parameter] public int PreselectedVehicleId { get; set; }

    private MudForm _form = null!;
    private bool _isValid;
    private Expense _model = new() { Description = string.Empty };
    private DateTime? _date;
    private List<Vehicle> _vehicles = [];

    protected override async Task OnInitializedAsync()
    {
        _vehicles = (await VehicleRepo.GetAllAsync()).ToList();

        if (Expense is not null)
        {
            _model = new Expense
            {
                Id = Expense.Id, VehicleId = Expense.VehicleId, Category = Expense.Category,
                Description = Expense.Description, Amount = Expense.Amount, Notes = Expense.Notes
            };
            _date = Expense.Date;
        }
        else
        {
            _model = new Expense { VehicleId = PreselectedVehicleId, Description = string.Empty };
            _date = DateTime.Today;
        }
    }

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid || _date is null) return;

        _model.Date = _date.Value;

        if (Expense is null)
            await ExpenseRepo.AddAsync(_model);
        else
            await ExpenseRepo.UpdateAsync(_model);

        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}
